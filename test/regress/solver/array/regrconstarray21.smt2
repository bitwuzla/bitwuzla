(set-option :preprocess false)
(declare-const v (_ BitVec 2))
(declare-const w (_ BitVec 2))
(declare-const x (_ BitVec 2))
(declare-const a (Array (_ BitVec 1) (_ BitVec 2)))
(define-fun av () (Array (_ BitVec 1) (_ BitVec 2)) ((as const (Array (_ BitVec 1) (_ BitVec 2))) v))
(define-fun aw () (Array (_ BitVec 1) (_ BitVec 2)) ((as const (Array (_ BitVec 1) (_ BitVec 2))) w))
(define-fun ax () (Array (_ BitVec 1) (_ BitVec 2)) ((as const (Array (_ BitVec 1) (_ BitVec 2))) x))

(declare-const iv1 (_ BitVec 1))
(declare-const iv2 (_ BitVec 1))
(declare-const iw1 (_ BitVec 1))
(declare-const iw2 (_ BitVec 1))
(declare-const ix1 (_ BitVec 1))
(declare-const ix2 (_ BitVec 1))
(declare-const uv1 (_ BitVec 2))
(declare-const uv2 (_ BitVec 2))
(declare-const uw1 (_ BitVec 2))
(declare-const uw2 (_ BitVec 2))
(declare-const ux1 (_ BitVec 2))
(declare-const ux2 (_ BitVec 2))

(assert (= (store (store av iv1 uv1) iv2 uv2) a))
(assert (= (store av iv1 uv1) (store a iv2 uv2)))
(assert (= (store (store aw iw1 uw1) iw2 uw2) a))
(assert (= (store (store ax ix1 ux1) ix2 ux2) a))
(assert (distinct v w x))
(set-info :status sat)
(check-sat)
