(set-logic QF_ABV)
(declare-const a (_ BitVec 1))
(declare-const b (_ BitVec 1))
(assert (= (store (store (store ((as const (Array (_ BitVec 1) (_ BitVec 1))) a) #b1 #b0) #b1 #b0) #b1 #b0)
           (store ((as const (Array (_ BitVec 1) (_ BitVec 1))) b) #b1 #b0)))
(assert (= (store (store ((as const (Array (_ BitVec 1) (_ BitVec 1))) a) #b0 #b0) #b1 #b0)
           (store ((as const (Array (_ BitVec 1) (_ BitVec 1))) b) #b0 #b0)))
(assert (distinct a b))
(set-info :status unsat)
(check-sat)
