(set-info :status unsat)
(declare-const x (_ BitVec 2))
(declare-const y (_ BitVec 2))
(declare-const i1 (_ BitVec 2))
(declare-const i2 (_ BitVec 2))
(declare-const e1 (_ BitVec 2))
(declare-const e2 (_ BitVec 2))
(define-fun Ax () (Array (_ BitVec 2) (_ BitVec 2)) ((as const (Array (_ BitVec 2) (_ BitVec 2))) x))
(define-fun Ay () (Array (_ BitVec 2) (_ BitVec 2)) ((as const (Array (_ BitVec 2) (_ BitVec 2))) y))
(assert (= (store Ax i1 e1) (store Ay i2 e2)))
(assert (distinct x y))
(assert (distinct i1 i2))
(assert (distinct e1 e2))
(check-sat)
