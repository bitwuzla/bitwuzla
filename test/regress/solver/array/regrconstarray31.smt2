           (store (store (store (store ((as const (Array (_ BitVec 2) (_ BitVec 2))) (_ bv1 2)) (_ bv0 2) (_ bv0 2)) i5 (_ bv0 2)) i (_ bv1 2)) (_ bv1 2) (_ bv1 2))))
