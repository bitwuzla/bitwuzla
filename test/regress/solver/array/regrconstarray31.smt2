(declare-const x2 (Array (_ BitVec 2) (_ BitVec 2)))
(declare-const i5 (_ BitVec 2))
(declare-const i  (_ BitVec 2))
(assert (= v #b01))
(assert (= (store x (_ bv0 2) (_ bv1 2))
           ((as const (Array (_ BitVec 2) (_ BitVec 2))) v)))
