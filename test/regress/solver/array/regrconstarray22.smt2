(declare-const v (_ BitVec 2))
(declare-const w (_ BitVec 2))
(declare-const x (_ BitVec 2))
(declare-const y (_ BitVec 2))
(declare-const a (Array (_ BitVec 2) (_ BitVec 2)))
(define-fun av () (Array (_ BitVec 2) (_ BitVec 2)) ((as const (Array (_ BitVec 2) (_ BitVec 2))) v))
(define-fun aw () (Array (_ BitVec 2) (_ BitVec 2)) ((as const (Array (_ BitVec 2) (_ BitVec 2))) w))
(define-fun ax () (Array (_ BitVec 2) (_ BitVec 2)) ((as const (Array (_ BitVec 2) (_ BitVec 2))) x))
(define-fun ay () (Array (_ BitVec 2) (_ BitVec 2)) ((as const (Array (_ BitVec 2) (_ BitVec 2))) y))

(declare-const iv1 (_ BitVec 2))
(declare-const iv2 (_ BitVec 2))
(declare-const iv3 (_ BitVec 2))
(declare-const iw1 (_ BitVec 2))
(declare-const iw2 (_ BitVec 2))
(declare-const iw3 (_ BitVec 2))
(declare-const ix1 (_ BitVec 2))
(declare-const ix2 (_ BitVec 2))
(declare-const ix3 (_ BitVec 2))
(declare-const iy1 (_ BitVec 2))
(declare-const iy2 (_ BitVec 2))
(declare-const iy3 (_ BitVec 2))
(declare-const uv1 (_ BitVec 2))
(declare-const uv2 (_ BitVec 2))
(declare-const uv3 (_ BitVec 2))
(declare-const uw1 (_ BitVec 2))
(declare-const uw2 (_ BitVec 2))
(declare-const uw3 (_ BitVec 2))
(declare-const ux1 (_ BitVec 2))
(declare-const ux2 (_ BitVec 2))
(declare-const ux3 (_ BitVec 2))
(declare-const uy1 (_ BitVec 2))
(declare-const uy2 (_ BitVec 2))
(declare-const uy3 (_ BitVec 2))

(assert (= (store av iv1 uv1) (store (store a iv2 uv2) iv3 uv3)))
(assert (= (store ax ix1 ux1) (store (store a ix2 ux2) ix3 ux3)))
(assert (= (store aw iw1 uw1) (store (store a iw2 uw2) iw3 uw3)))
(assert (= (store ay iy1 uy1) (store (store a iy2 uy2) iy3 uy3)))
(assert (distinct v w x y))
(set-info :status sat)
(check-sat)
